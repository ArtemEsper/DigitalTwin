# ============================================================
# Digital Twin — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://digitaltwin:changeme@postgres:5432/digitaltwin

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM Provider ---
# Options: anthropic | openai | local
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Local LLM via Ollama/vLLM (used when LLM_PROVIDER=local)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3
LOCAL_EMBED_MODEL=nomic-embed-text

# --- API Security ---
# Change this before any deployment
ADMIN_API_KEY=change-me-in-production

# --- Memory ---
# Embedding vector dimension — must match the model used
# OpenAI text-embedding-3-small: 1536
# Voyage AI voyage-3: 1024
EMBEDDING_DIM=1024

# --- Subject ---
# Identifier for the person being represented
SUBJECT_ID=default

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

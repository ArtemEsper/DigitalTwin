# Secrets — never commit
.env
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Docker
*.log

# MemPalace (generated files, palace lives in ~/.mempalace)
entities.json
mempalace.yaml

# Terraform — never commit state or local variable files
terraform/terraform.tfvars
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfstate.*.backup
terraform/.terraform/
terraform/.terraform.lock.hcl

# IDE
.idea/
.vscode/
*.swp
memory_export.sql

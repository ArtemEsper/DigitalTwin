# GCP Project Configuration
project_id = "digitaltwin-gcp-pr"
region     = "europe-central2"
zone       = "europe-central2-a"
environment = "dev"

# VM Configuration
vm_machine_type = "e2-medium"
postgres_disk_size = 50

# Network Configuration
network_name = "digitaltwin-network"
subnet_name  = "digitaltwin-subnet"

# Slack Configuration (get from https://api.slack.com/apps)
slack_signing_secret = "daced5b7a00d2cc23332a49f82193f3e"
slack_bot_token = ""  # Set in GCP Console: Secret Manager > slack-bot-token

# Application Secrets (will be stored in Secret Manager - set these in GCP Console)
anthropic_api_key = ""  # Set in GCP Console: Secret Manager > anthropic-api-key
admin_api_key = "your-secure-admin-key-change-this"
voyage_api_key = ""     # Set in GCP Console: Secret Manager > voyage-api-key
subject_id = "default"

# Database Configuration (if using Cloud SQL instead of VM-based)
postgres_version = "POSTGRES_15"
postgres_tier    = "db-f1-micro"
